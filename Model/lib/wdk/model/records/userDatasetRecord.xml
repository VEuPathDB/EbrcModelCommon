<?xml version="1.0" encoding="UTF-8"?>

<wdkModel>


  <constant name="datasetRecordDisplayName">User Dataset</constant>
  <constant name="datasetRecordDisplayNamePlural">User Datasets</constant>


  <recordClassSet name="UserDatasetRecordClasses">

    <!-- ======================================= USER DATASET RECORD CLASS =========================================================== -->

    <recordClass name="UserDatasetRecordClass" displayName="%%datasetRecordDisplayName%%" displayNamePlural="%%datasetRecordDisplayNamePlural%%" urlName="userdataset" useBasket="false" >
      <testParamValues>
        <paramValue name="dataset_id">test123</paramValue>
      </testParamValues>

      <!-- Primary key definition -->
      <primaryKey aliasQueryRef="UserDatasetAttributes.DatasetAlias">
        <columnRef>dataset_id</columnRef>
      </primaryKey>

      <idAttribute name="primary_key" displayName="Dataset name"
                   help="Click a user dataset to open its associated page.">
        <text>
          <![CDATA[ $$name$$ ]]>
        </text>
      </idAttribute>

      <!-- =============================================================== -->
      <!--   Reporters -->
      <!-- =============================================================== -->

      <reporter name="attributesTabular" displayName="Summary - tab delimited" scopes="results"
                implementation="org.gusdb.wdk.model.report.reporter.AttributesTabularReporter">
        <property name="page_size">500</property>
      </reporter>

      <reporter name="tableTabular" displayName="%%tableReporterDisplayName%%" scopes="results"
                implementation="org.gusdb.wdk.model.report.reporter.TableTabularReporter">
        <property name="page_size">1000000</property>
      </reporter>

      <reporter name="fullRecord" displayName="%%fullReporterDisplayName%%" scopes="record"
                implementation="org.gusdb.wdk.model.report.reporter.FullRecordReporter">
      </reporter>

      <reporter name="xml" displayName="XML: choose from columns and/or tables" scopes=""
                implementation="org.gusdb.wdk.model.report.reporter.XMLReporter">
      </reporter>

      <reporter name="json" displayName="json: choose from columns and/or tables" scopes=""
                implementation="org.gusdb.wdk.model.report.reporter.JSONReporter">
      </reporter>

      <!-- =============================================================== -->
      <!--   Core Attributes -->
      <!-- =============================================================== -->


      <attributesList summary="name,owner,type_name,accessibility,creation_date,summary"/>

      <attributeQueryRef ref="UserDatasetAttributes.OwnerInfo">
        <columnAttribute name="owner_name" displayName="Uploaded by" help="The person or organization who uploaded this dataset to this database."/>
        <columnAttribute name="owner_organization" displayName="Uploader organization" help="Organization of the dataset owner."/>
      </attributeQueryRef>

      <attributeQueryRef ref="UserDatasetAttributes.CoreMetadata">
        <columnAttribute name="owner" displayName="Owner ID" help="User ID of the dataset owner."/>
        <columnAttribute name="type_name" displayName="internal data type name" />
        <columnAttribute name="type_version" displayName="Type Version" help=""/>
        <columnAttribute name="category" displayName="Data type" help="The data type classifies the dataset according to the biological characteristics and structure of the data it contains."/>
        <columnAttribute name="deleted_status" displayName="Deleted status"
                         help="0 = Active, 1 = Deleted and Uninstalled, 2 = Deleted but not yet Uninstalled"/>
        <columnAttribute name="is_public" displayName="Community" help="‘Public’ datasets have no access restrictions and can be downloaded by anyone. ‘Restricted’ datasets can only be downloaded by the dataset owner and collaborators the owner has explicitly invited." />
        <columnAttribute name="accessibility" displayName="Visibility"
                         help="‘Discoverable’ datasets are findable and explorable by the research community. ‘Private’ datasets can only be discovered and explored by the dataset owner and collaborators the owner has explicitly invited." />
        <columnAttribute name="days_for_approval" displayName="Days for approval"
                         help="Number of days required for approval"/>
        <columnAttribute name="creation_date" displayName="Created" help="The date the dataset was first uploaded." />
      </attributeQueryRef>

         <textAttribute name="dataFiles" displayName="Dataset files">
           <display>YES</display>
           <text>YES</text>
         </textAttribute>

      <attributeQueryRef ref="UserDatasetAttributes.DescriptiveMetadata">
        <columnAttribute name="name" displayName="Name" help="Dataset name"/>
        <columnAttribute name="summary" displayName="Summary" sortable="false" help="A short description of the dataset"/>
        <columnAttribute name="description" displayName="Description" sortable="false"
                         help="Free text entered by the author"/>
        <columnAttribute name="disclaimer" displayName="Reuse considerations" help="Any important caveats or limitations users should consider when interpreting or reusing this dataset, or requests from the data provider stipulating the proper use of unpublished data."/>
	<columnAttribute name="program_name" displayName="Program" help="Program name"/>
        <columnAttribute name="project_name" displayName="Project" help="Project name"/>
        <columnAttribute name="short_attribution" displayName="Attribution" help="Short attribution text"/>
        <columnAttribute name="short_name" displayName="Short name" help="Abbreviated dataset name"/>
      </attributeQueryRef>

      <attributeQueryRef ref="UserDatasetAttributes.EdaStudyMapping">
        <columnAttribute name="eda_study_id" displayName="EDA Study ID" help="EDA study identifier"/>
      </attributeQueryRef>

      <attributeQueryRef ref="UserDatasetAttributes.PrimaryContact">
        <columnAttribute name="primary_contact_name" displayName="Primary contact" help="The person or organization that serves as a source of information concerning this dataset."/>
        <columnAttribute name="primary_affiliation" displayName="Primary contact affiliation" help="The institution where the contact person is located."/>
        <columnAttribute name="primary_email" displayName="Primary contact email" help="The email address for the contact person or organization for this dataset."/>
        <columnAttribute name="primary_country" displayName="Primary contact country" help=""/>
      </attributeQueryRef>

      <!-- phase 2
      <attributeQueryRef ref="UserDatasetAttributes.PrimaryPublication">
        <columnAttribute name="primary_publication" displayName="Primary publication" help=""/>
      </attributeQueryRef>
      -->
      
      <attributeQueryRef ref="UserDatasetAttributes.Characteristics">
        <columnAttribute name="study_design" displayName="Study design"/>
        <columnAttribute name="study_type" displayName="Investigation type"/>
        <columnAttribute name="participant_ages" displayName="Participant ages"/>
        <columnAttribute name="sample_year_start" displayName="Start year"/>
        <columnAttribute name="sample_year_end" displayName="End year"/>
      </attributeQueryRef>

      <attributeQueryRef ref="UserDatasetAttributes.ClinicalOrField">
        <columnAttribute name="is_clinical_field" displayName="Field study or Clinical trial" help="Whether the dataset or underlying samples originated from a human, vector, animal, or plant population study; an epidemiological or surveillance study; or a clinical trial."/>
      </attributeQueryRef>

      <attributeQueryRef ref="UserDatasetAttributes.OutcomesList">
        <columnAttribute name="outcomes_list" displayName="Outcomes of interest" help="For field studies and clinical trials: primary disease, condition, or outcome being studied."/>
      </attributeQueryRef>

      <!-- =============================================================== -->
      <!--   Tables -->
      <!-- =============================================================== -->

      <!--++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++-->
      <!-- References --> 
      <!--++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++-->
<!-- TODO will return search , name hardcoded based on dataset type

      <table name="References" excludeProjects="ClinEpiDB,MicrobiomeDB"
             displayName="Explore this Dataset within this Website"
             queryRef="GenomeDatasetTables.References">
        <columnAttribute name="dataset_id"  inReportMaker="false" internal="true"/>
        <columnAttribute name="dataset_name"  inReportMaker="false" internal="true"/>
        <columnAttribute name="text" inReportMaker="false" internal="true"/>
        <columnAttribute name="url" inReportMaker="false" internal="true"/>
        <columnAttribute name="description" inReportMaker="false" internal="true"/>
        <columnAttribute name="record_type" displayName="Record Type" />
        <columnAttribute name="target_type" displayName="Type of Reference"/>
        <columnAttribute name="target_name" displayName="Name"/>
        <columnAttribute name="link_type" displayName="link_type"/>
      </table>   
-->
      <!--++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++-->
      <!-- Selected Publications -->
      <!--++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++-->
      <!-- phase 2
      <table name="Publications"
             displayName="Selected Publications"
             queryRef="UserDatasetTables.Publications">
        <columnAttribute name="dataset_id" inReportMaker="false" internal="true"/>
        <columnAttribute name="external_id" displayName="ID" internal="true"/>
        <columnAttribute name="type" displayName="Type"/>
        <columnAttribute name="citation" displayName="Citation" internal="true"/>
        <columnAttribute name="is_primary" displayName="Primary" internal="true"/>
        <columnAttribute name="url" internal="true"/>

        <linkAttribute name="publication_link" displayName="Link">
          <displayText>
            <![CDATA[
              $$citation$$
            ]]>
          </displayText>
          <url>
            <![CDATA[
              $$url$$
            ]]>
          </url>
        </linkAttribute>
      </table>
      -->
      <!--++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++-->
      <!-- Principal Investigator and Collaborators -->
      <!--++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++-->
      <table name="Contacts"
             displayName="Principal investigator and collaborators"
             queryRef="UserDatasetTables.Contacts">
        <columnAttribute name="dataset_id" inReportMaker="false" internal="true"/>
        <columnAttribute name="contact_name" displayName="Name"/>
        <columnAttribute name="affiliation" displayName="Affiliation"/>
        <columnAttribute name="email" displayName="Email"/>
        <columnAttribute name="country" displayName="Country"/>
        <columnAttribute name="is_primary" displayName="Primary contact"/>
      </table>

      <!--++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++-->
      <!-- Organisms -->
      <!--++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++-->
      <table name="Organisms" excludeProjects="ClinEpiDB,MicrobiomeDB" 
             displayName="Organisms"
             queryRef="UserDatasetTables.Organisms">
        <columnAttribute name="dataset_id" inReportMaker="false" internal="true"/>
        <columnAttribute name="species" displayName="Study population species" help="For field studies and clinical trials: scientific name of the population the study is based on, even if the dataset contains laboratory measurements on pathogens or other organisms"/>
        <columnAttribute name="strain" displayName="Strain"/>
      </table>

      <!--++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++-->
      <!-- Factors -->
      <!--++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++-->
      <table name="Factors" help="For field studies and clinical trials: pathogen, exposure, or risk factor associated with the outcome."
             displayName="Associated factors"
             queryRef="UserDatasetTables.AssociatedFactors">
        <columnAttribute name="dataset_id" inReportMaker="false" internal="true"/>
        <columnAttribute name="factor" displayName="Factor"/>
      </table>

      <!--++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++-->
      <!-- External Resources -->
      <!--++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++-->
      <!-- phase 2
      <table name="HyperLinks"
             displayName="External Resources"
             queryRef="UserDatasetTables.HyperLinks">
        <columnAttribute name="dataset_id" inReportMaker="false" internal="true"/>
        <columnAttribute name="url" internal="true"/>
        <columnAttribute name="description" internal="true"/>

        <linkAttribute name="hyper_link" displayName="Link">
          <displayText>
            <![CDATA[
              $$description$$
            ]]>
          </displayText>
          <url>
            <![CDATA[
              $$url$$
            ]]>
          </url>
        </linkAttribute>
      </table>
      -->
      
      <!--++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++-->
      <!-- Funding -->
      <!--++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++-->
      <table name="FundingAwards"
             displayName="Funding"
             queryRef="UserDatasetTables.FundingAwards">
        <columnAttribute name="dataset_id" inReportMaker="false" internal="true"/>
        <columnAttribute name="agency" displayName="Funding agency"/>
        <columnAttribute name="award_number" displayName="Award number"/>
      </table>

      <!--++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++-->
      <!-- Countries -->
      <!--++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++-->
      <table name="Countries" help="For field studies and clinical trials: a list of the countries where data or samples were collected from the study population."
             displayName="Countries"
             queryRef="UserDatasetTables.Countries">
        <columnAttribute name="dataset_id" inReportMaker="false" internal="true"/>
        <columnAttribute name="country" displayName="Country"/>
      </table>

      <!--++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++-->
      <!-- Study population species -->
      <!--++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++-->
      <table name="Species"
             displayName="Study population species"
             queryRef="UserDatasetTables.Species">
        <columnAttribute name="dataset_id" inReportMaker="false" internal="true"/>
        <columnAttribute name="species" displayName="Species"/>
      </table>

      <!--++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++-->
      <!-- Outcomes of interest -->
      <!--++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++-->
      <table name="Outcomes" help="For field studies and clinical trials: primary disease, condition, or outcome being studied."
             displayName="Outcomes of interest"
             queryRef="UserDatasetTables.Outcomes">
        <columnAttribute name="dataset_id" inReportMaker="false" internal="true"/>
        <columnAttribute name="outcome" displayName="Outcome"/>
      </table>

      <!--++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++-->
      <!-- Field Study or Clinical Trial - Characteristics -->
      <!--++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++-->
      <table name="Characteristics"
             displayName="Field study or clinical trial - Characteristics"
             queryRef="UserDatasetTables.Characteristics">
        <columnAttribute name="dataset_id" inReportMaker="false" internal="true"/>
        <columnAttribute name="study_design" displayName="Study design" help="For field studies and clinical trials: describes the overall structure and methodology used to conduct the study."/>
        <columnAttribute name="study_type" displayName="Investigation type" help="For field studies and clinical trials: indicates whether the dataset was generated through observational or experimental investigation."/>
        <columnAttribute name="participant_ages" displayName="Participant ages" help="For field studies and clinical trials: age range(s) of participants when data were collected."/>
        <columnAttribute name="sample_year_start" displayName="Start year" help="For field studies and clinical trials: year when data collection was initiated."/>
        <columnAttribute name="sample_year_end" displayName="End year" help="For field studies and clinical trials: year when data collection concluded."/>
      </table>

      <!--++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++-->
      <!-- Project and Programmatic Affiliations -->
      <!--++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++-->
      <table name="Projects"
             displayName="Project and programmatic affiliations"
             queryRef="UserDatasetTables.Projects">
        <columnAttribute name="dataset_id" inReportMaker="false" internal="true"/>
        <columnAttribute name="project_id" displayName="Project ID"/>
      </table>

      <!--++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++-->
      <!-- Sample types -->
      <!--++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++-->
      <table name="SampleTypes" help="For field studies and clinical trials: a list of the types of biological or environmental samples represented in this dataset."
             displayName="Sample types"
             queryRef="UserDatasetTables.SampleTypes">
        <columnAttribute name="dataset_id" inReportMaker="false" internal="true"/>
        <columnAttribute name="type" displayName="Type"/>
      </table>

      <!--++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++-->
      <!-- Dataset Sources -->
      <!--++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++-->
      <table name="DataSources"
             displayName="External sources"
             queryRef="UserDatasetTables.DataSources">
        <columnAttribute name="dataset_id" inReportMaker="false" internal="true"/>
        <columnAttribute name="url" displayName="URL"/>
        <columnAttribute name="version" displayName="Version"/>
      </table>

      <!--++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++-->
      <!-- External Identifiers - Dataset Sources -->
      <!--++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++-->
      <!-- phase 2
      <table name="ExternalIds"
             displayName="External Identifiers"
             queryRef="UserDatasetTables.ExternalIds">
        <columnAttribute name="dataset_id" inReportMaker="false" internal="true"/>
        <columnAttribute name="identifier_type" displayName="Type"/>
        <columnAttribute name="identifier_value" displayName="Identifier"/>
      </table>
      -->

      <!--++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++-->
      <!-- VEuPathDB Related Datasets -->
      <!--++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++-->
      <!-- phase 2
      <table name="LinkedDatasets"
             displayName="VEuPathDB Related Datasets"
             queryRef="UserDatasetTables.LinkedDatasets">
        <columnAttribute name="dataset_id" inReportMaker="false" internal="true"/>
        <columnAttribute name="linked_dataset_id" displayName="Linked Dataset ID"/>
        <columnAttribute name="linked_dataset_type" displayName="Linked Dataset Type"/>
        <columnAttribute name="shares_records" displayName="Shares Records"/>
      </table>
      -->
      
      <!--++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++-->
      <!-- Explore this Dataset within this Website -->
      <!--++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++++-->
      <table name="ExploreWebsite"
             displayName="Explore this dataset within this website"
             queryRef="UserDatasetTables.ExploreWebsite">
        <columnAttribute name="dataset_id"  internal="true"/>
        <columnAttribute name="url" internal="true"/>
	<columnAttribute name="description" internal="true"/>
        <columnAttribute name="order" internal="true"/>

	<linkAttribute name="eda_link" displayName="Link">
          <displayText>
            <![CDATA[
              $$description$$
            ]]>
          </displayText>
          <url>
            <![CDATA[
              $$url$$
            ]]>
          </url>
        </linkAttribute>	            
      </table>

      <table name="Variables"
             displayName="Variables"
             queryRef="UserDatasetTables.Variables">
        <columnAttribute name="dataset_id" internal="true"/>
        <columnAttribute name="entity_name" displayName="Entity name"/>
        <columnAttribute name="provider_label" displayName="Variable name"/>
        <columnAttribute name="display_name" displayName="Variable label"/>
        <columnAttribute name="definition" displayName="Variable definition"/>
        <columnAttribute name="data_type" displayName="Variable data type"/>
      </table>
      
    </recordClass>

  </recordClassSet>

</wdkModel>

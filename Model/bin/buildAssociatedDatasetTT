#!/usr/bin/perl

use strict;

use lib "$ENV{GUS_HOME}/lib/perl";

use DBI;
use Getopt::Long qw(GetOptions);
use Data::Dumper;
use EbrcModelCommon::Model::tmUtils;
use LWP::Simple;
use JSON;

my ($help, $propfile, $instance, $schema, $suffix, $prefix, $filterValue, $debug);

Getopt::Long::Configure("pass_through");
GetOptions("propfile=s"    => \$propfile,
           "instance=s"    => \$instance,
           "schema=s"      => \$schema,
           "suffix=s"      => \$suffix,
           "prefix=s"      => \$prefix,
           "filterValue=s" => \$filterValue,
           "debug!"        => \$debug,
           "help|h"        => \$help,
          );

usage() if $help;

die "required parameter missing" unless ($propfile && $instance && $suffix);

my $dbh = EbrcModelCommon::Model::tmUtils::getDbHandle($instance, $schema, $propfile);

$dbh->do(<<SQL) or die $dbh->errstr;
   create table AssociatedDataset$suffix (
      local_dataset_id      varchar(15),
      local_project         varchar(20),
      pubmed_id             varchar(60),
      associated_dataset_id varchar(15),
      project               varchar(20),
      webapp_name           varchar(20),
      display_name          varchar(200)
   )
SQL

my %projects = (
    'ameb' => 'AmoebaDB',
    'cryp' => 'CryptoDB',
    'giar' => 'GiardiaDB',
    'host' => 'HostDB',
    'micr' => 'MicrosporidiaDB',
    'piro' => 'PiroplasmaDB',
    'plas' => 'PlasmoDB',
    'toxo' => 'ToxoDB',
    'tvag' => 'TrichDB',
    'tryp' => 'TriTrypDB',
    'fung' => 'FungiDB',
    'vect' => 'VectorBase',
    'clin' => 'ClinEpiDB',
    'mbio' => 'MicrobiomeDB',
);

my %webapps = (
    'ameb' => 'amoeba',
    'cryp' => 'cryptodb',
    'giar' => 'giardiadb',
    'host' => 'hostdb',
    'micr' => 'micro',
    'piro' => 'piro',
    'plas' => 'plasmo',
    'toxo' => 'toxo',
    'tvag' => 'trichdb',
    'tryp' => 'tritrypdb',
    'fung' => 'fungidb',
    'vect' => 'vectorbase',
    'clin' => 'ce',
    'mbio' => 'mbio',
    'eda-' => {'clin', 1, 'mbio', 1, 'vect', 1},
);

# Reverse maps: project_id (from DatasetDatasource) -> project display name and webapp name.
# GenomicsDB datasets (GO, pathways, etc.) are surfaced under the VEuPathDB umbrella.
my (%projectIdToName, %projectIdToWebapp);
foreach my $key (keys %projects) {
    next if ref($webapps{$key});  # skip eda- hash-valued entry
    $projectIdToName{$projects{$key}}   = $projects{$key};
    $projectIdToWebapp{$projects{$key}} = $webapps{$key};
}
$projectIdToName{'GenomicsDB'}   = 'VEuPathDB';
$projectIdToWebapp{'GenomicsDB'} = 'veupathdb';

my $insertStmt = $dbh->prepare(<<SQL) or die $dbh->errstr;
   insert into AssociatedDataset$suffix
   (local_dataset_id, pubmed_id, associated_dataset_id, project, webapp_name, display_name, local_project)
   values (?, ?, ?, ?, ?, ?, ?)
SQL

# Fetch all local datasets that have a non-empty PubMed ID.
my $stmt = $dbh->prepare(<<SQL) or die $dbh->errstr;
   select ds.project_id, dpres.dataset_presenter_id, dpub.pmid, dpres.display_name
   from DatasetPresenter dpres, DatasetPublication dpub, DatasetDatasource ds
   where dpres.dataset_presenter_id = dpub.dataset_presenter_id
     and dpres.dataset_presenter_id = ds.dataset_presenter_id
     and dpub.pmid is not null
     and dpub.pmid != ''
   order by pmid, dataset_presenter_id
SQL

$stmt->execute() or die $dbh->errstr;

my (@projectId, @localDatasetId, @localPmid, @displayName);
my $localDatasets = 0;

while (($projectId[$localDatasets], $localDatasetId[$localDatasets],
        $localPmid[$localDatasets], $displayName[$localDatasets])
       = $stmt->fetchrow_array()) {
    $localDatasets++;
}
$stmt->finish();
print "fetched $localDatasets local datasets\n";

# Determine instance type, host for web service calls, and which projects are external.
my $isGenomicsDB = ($instance =~ /genomicsdb/i);

my $host;
if    ($instance =~ /^rm/ || $instance =~ /-/) { $host = "qa";  }
elsif ($isGenomicsDB)                           { $host = "b1";  }
else                                            { $host = "www"; }

# For genomicsdb, all genomic projects are local; only ClinEpiDB and MicrobiomeDB are external.
# For single-project/EDA instances, derive local projects from the instance name.
my ($webappProjects, @externalProjectKeys);
if ($isGenomicsDB) {
    @externalProjectKeys = ('clin', 'mbio');
} else {
    (my $strippedInstance = $instance) =~ s/^rm//;
    my $instanceProject = substr($strippedInstance, 0, 4);
    $webappProjects = $webapps{$instanceProject};
    unless (ref($webappProjects) eq 'HASH') {
        $webappProjects = { $webappProjects => 1 };
    }
    @externalProjectKeys = grep { !$webappProjects->{$_} && !ref($webapps{$_}) } keys %projects;
}

my $insertCount = 0;

# --- Local associations ---
if ($isGenomicsDB) {
    # All genomic projects are in this DB. Associate any pair of local datasets
    # sharing a pmid, regardless of project.
    print "checking for associations among all local projects\n";
    for my $iLocal (0 .. $localDatasets - 1) {
        for my $iAssociated (0 .. $localDatasets - 1) {
            next if $iLocal == $iAssociated;
            next unless $localPmid[$iLocal] eq $localPmid[$iAssociated];
            next unless $localDatasetId[$iLocal] ne $localDatasetId[$iAssociated];

            my $assocProject = $projectIdToName{$projectId[$iAssociated]};
            my $assocWebapp  = $projectIdToWebapp{$projectId[$iAssociated]};
            next unless $assocProject && $assocWebapp;

            $insertStmt->execute(
                $localDatasetId[$iLocal],    $localPmid[$iLocal],
                $localDatasetId[$iAssociated],
                $assocProject,               $assocWebapp,
                $displayName[$iAssociated],
                $projectIdToName{$projectId[$iLocal]}
            ) or die "inserting local record for \"$localDatasetId[$iLocal]\": " . $dbh->errstr;
            $insertCount++;
        }
    }
} else {
    # Single-project or EDA instance: associate datasets within each local project.
    foreach my $localProject (keys %$webappProjects) {
        next unless $webapps{$localProject};
        printf("checking for associations within project %s\n", $projects{$localProject});

        for my $iLocal (0 .. $localDatasets - 1) {
            next unless $projects{$localProject} eq $projectId[$iLocal];

            for my $iAssociated (0 .. $localDatasets - 1) {
                next unless $iLocal != $iAssociated
                    && $projectId[$iLocal]    eq $projectId[$iAssociated]
                    && $localPmid[$iLocal]    eq $localPmid[$iAssociated]
                    && $localDatasetId[$iLocal] ne $localDatasetId[$iAssociated];

                $insertStmt->execute(
                    $localDatasetId[$iLocal],    $localPmid[$iLocal],
                    $localDatasetId[$iAssociated],
                    $projects{$localProject},    $webapps{$localProject},
                    $displayName[$iAssociated],
                    $projectId[$iLocal]
                ) or die "inserting local record for \"$localDatasetId[$iLocal]\": " . $dbh->errstr;
                $insertCount++;
            }
        }
    }
}
print "inserted $insertCount local association records\n";

# --- External associations (via web service) ---
foreach my $projectKey (@externalProjectKeys) {
    my $url = "https://$host.$projects{$projectKey}.org/$webapps{$projectKey}"
            . "/service/record-types/dataset/searches/AllDatasets/reports/standard"
            . "?reportConfig=%7B%22attributes%22%3A%5B%22primary_key%22%5D%2C%22tables%22%3A%5B%22Publications%22%5D%2C%22attributeFormat%22%3A%22text%22%7D";

    my $datasetsJson = getData($url);

    foreach my $record (@{$datasetsJson->{records}}) {
        my $displayName = $record->{displayName};

        foreach my $pubrec (@{$record->{tables}->{Publications}}) {
            next unless $pubrec->{pmid} && $pubrec->{pmid} ne '';

            for my $i (0 .. $localDatasets - 1) {
                next unless $pubrec->{pmid} eq $localPmid[$i]
                    && $localDatasetId[$i] ne $pubrec->{dataset_id};

                $insertStmt->execute(
                    $localDatasetId[$i],    $localPmid[$i],
                    $pubrec->{dataset_id},
                    $projects{$projectKey}, $webapps{$projectKey},
                    $displayName,
                    $projectIdToName{$projectId[$i]}
                ) or die "inserting external record for \"$localDatasetId[$i]\": " . $dbh->errstr;
                $insertCount++;
            }
        }
    }
}

$dbh->commit();
print "inserted $insertCount total records\n";

$dbh->do(<<SQL) or die $dbh->errstr;
   create index ldsix$suffix
      on AssociatedDataset$suffix (local_dataset_id, pubmed_id)
SQL

$dbh->disconnect();

sub usage {
    my $e = shift;
    print STDERR "$e\n" if $e;
    print STDERR "
Build a table of associations between datasets sharing PubMed IDs, across projects.

usage: buildAssociatedDatasetTT -propfile prop_file -instance instance -schema schema -suffix suffix [-debug] [-help]
";
    exit;
}

sub getData {
    my ($url) = @_;
    my $json = get($url);
    die "Couldn't get $url" unless defined $json;
    die "Error in response at URL $url" if $json =~ /\*\*\*\*\*\*\* ERROR \*\*\*\*\*\*\*/;
    return decode_json($json);
}

1;
